model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  password String

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultPetId String? @db.Uuid @unique
  defaultPet   Pet?    @relation("defaultPet", fields: [defaultPetId], references: [id])

  pets Pet[]

  @@map("users")
}
